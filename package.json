{
  "name": "voxel",
  "version": "1.0.3",
  "description": "The open-source Roblox launcher.",
  "main": "./out/main/index.js",
  "author": "nick (6E6B)",
  "homepage": "https://github.com/6E6B/voxel",
  "scripts": {
    "preview": "electron-vite preview",
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "rebuild:native": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --config electron-builder.yml --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@ryuziii/discord-rpc": "^1.0.1-rc.1",
    "@tanstack/react-query": "^5.90.11",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/xml2js": "^0.4.14",
    "better-sqlite3": "^12.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.3",
    "electron-log": "^5.4.3",
    "electron-trpc": "^0.7.1",
    "electron-updater": "^6.6.2",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.23.24",
    "fzstd": "^0.1.1",
    "koffi": "^2.14.1",
    "lightweight-charts": "^5.0.9",
    "lucide-react": "^0.554.0",
    "lz4js": "^0.2.0",
    "multithreading": "^0.3.37",
    "react-syntax-highlighter": "^16.1.0",
    "react-virtuoso": "^4.16.1",
    "roavatar-renderer": "^1.2.12",
    "roblox-bat": "^0.6.0",
    "tailwind-merge": "^3.4.0",
    "xml2js": "^0.6.2",
    "yauzl": "^3.3.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/discord-rpc": "^4.0.10",
    "@types/flexsearch": "^0.7.6",
    "@types/glob": "^8.1.0",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.22",
    "electron": "^38.1.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.17",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.6"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4",
    "rollup": "^4.60.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "koffi"
    ]
  }
}